# PBRTConductor PT oracle: unit quad. eta = baseColor, k = transmissionColor,
# anisotropic roughness = specular.rg.
mat = PBRTConductorMaterial('pbrtConductor')
mat.baseColor = float4(0.2, 0.9, 1.4, 1.0)
mat.transmissionColor = float3(3.9, 2.5, 2.1)
mat.roughness = float2(0.3, 0.5)

quadMesh = TriangleMesh.createQuad(float2(1.0, 1.0))
meshID = sceneBuilder.addTriangleMesh(quadMesh, mat)
nodeID = sceneBuilder.addNode('quad', Transform(translation=float3(0.5, 0.5, 0.0), rotationEulerDeg=float3(90.0, 0.0, 0.0)))
sceneBuilder.addMeshInstance(nodeID, meshID)

light = PointLight('oracleLight')
light.position = float3(0.5, 0.5, 1.5)
light.intensity = float3(3.0, 3.0, 3.0)
sceneBuilder.addLight(light)
